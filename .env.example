# Student Success Platform Configuration

# API settings
API_TITLE=Student Success Platform API
API_VERSION=1.0.0
API_PREFIX=/api/v1
DEBUG=false

# LLM Provider: "openai" or "ollama"
LLM_PROVIDER=openai
LLM_TIMEOUT=30.0
LLM_ENABLED=true

# OpenAI Settings (required if LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=  # Optional: for Azure OpenAI or proxies

# Ollama Settings (used if LLM_PROVIDER=ollama or as fallback)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=deepseek-r1:1.5b
